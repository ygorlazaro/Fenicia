{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-auth",
      "type": "dotnet",
      "command": "dotnet build",
      "args": [
        "${workspaceRoot}/Fenicia.Auth/Fenicia.Auth.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-projects",
      "type": "dotnet",
      "command": "dotnet build",
      "args": [
        "${workspaceRoot}/Fenicia.Module.Projects/Fenicia.Module.Projects.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "docker-build-all",
      "type": "shell",
      "command": "docker-compose -f Docker/docker-compose.yml build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "docker-up",
      "type": "shell",
      "command": "docker-compose -f Docker/docker-compose.yml up -d",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "docker-down",
      "type": "shell",
      "command": "docker-compose -f Docker/docker-compose.yml down",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "docker-logs",
      "type": "shell",
      "command": "docker-compose -f Docker/docker-compose.yml logs -f",
      "problemMatcher": []
    },
    {
      "label": "docker-restart-auth",
      "type": "shell",
      "command": "docker restart fenicia-auth",
      "problemMatcher": []
    },
    {
      "label": "docker-restart-projects",
      "type": "shell",
      "command": "docker restart fenicia-module-projects",
      "problemMatcher": []
    }
  ]
}
