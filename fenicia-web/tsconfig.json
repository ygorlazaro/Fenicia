{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*",
    "src/**/**/*"
  ],
  "exclude": [
    "src/views/base/**/*",
    "src/views/buttons/**/*",
    "src/views/forms/**/*",
    "src/views/icons/**/*",
    "src/views/notifications/**/*",
    "src/views/widgets/**/*",
    "src/views/charts/**/*",
    "src/views/dashboard/**/*",
    "node_modules"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
