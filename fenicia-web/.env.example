# API Base URLs for Microservices
# Copy this file to .env and update the values for your environment

# Authentication Microservice (handles login, register, users, companies, tokens)
VITE_AUTH_API_BASE_URL=http://localhost:5144

# Basic Module Microservice (handles employees, positions, customers, suppliers, products, inventory, orders)
VITE_BASIC_API_BASE_URL=http://localhost:5083

# Main API (general purpose, if needed)
VITE_API_BASE_URL=http://localhost:5000

# Default Company ID for anonymous requests (used during login before company selection)
# Format: UUID (GUID)
VITE_DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000000
