# =============================================================================
# Fenicia Platform - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fenicia
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Connection String for .NET services
CONNECTION_STRING_AUTH=Host=postgres;Port=5432;Database=fenicia;Username=postgres;Password=postgres

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Seq Logging Configuration
# -----------------------------------------------------------------------------
SEQ_URL=http://seq:5341

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ISSUER=AuthService
JWT_AUDIENCE=FeniciaPlatform

# -----------------------------------------------------------------------------
# API Base URLs (for frontend)
# -----------------------------------------------------------------------------
VITE_AUTH_API_BASE_URL=http://localhost:5000/api
VITE_BASIC_API_BASE_URL=http://localhost:5002/api
VITE_PROJECTS_API_BASE_URL=http://localhost:5144/api

# -----------------------------------------------------------------------------
# Service Ports (HTTP/HTTPS)
# -----------------------------------------------------------------------------
AUTH_PORT_HTTP=5000
AUTH_PORT_HTTPS=5001
BASIC_PORT_HTTP=5002
BASIC_PORT_HTTPS=5003
PROJECTS_PORT_HTTP=5144
PROJECTS_PORT_HTTPS=5145

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
WEB_PORT=3000

# -----------------------------------------------------------------------------
# Debugging Configuration
# -----------------------------------------------------------------------------
DOTNET_ENVIRONMENT=Development
ASPNETCORE_DETAILEDERRORS=true
