{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Auth": "Host=localhost;Database=fenicia;Username=postgres;Password=postgres"
  },
  "IpRateLimiting": {
    "ClientIdHeader": "X-ClientId",
    "EnableEndpointRateLimiting": true,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Limit": 30,
        "Period": "10s"
      },
      {
        "Endpoint": "POST:/token/refresh",
        "Limit": 3,
        "Period": "1m"
      }
    ],
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "StackBlockedRequests": false
  },
  "IpRateLimitPolicies": {
    "IpRules": [
      {
        "Ip": "127.0.0.1",
        "Rules": [
          {
            "Endpoint": "*",
            "Limit": 10,
            "Period": "10s"
          }
        ]
      }
    ]
  },
  "Jwt": {
    "Secret": "875ecb60-6047-4947-8f4a-91972bd8fc44"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "FeniciaAuthRedisInstance"
  },
  "Seq": {
    "Url": "http://localhost:5341"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Error",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  }
}
